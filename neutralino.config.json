{
  "$schema": "https://raw.githubusercontent.com/neutralinojs/neutralinojs/main/schemas/neutralino.config.schema.json",
  "applicationId": "com.neudeskcli.app",
  "version": "1.0.0",
  "defaultMode": "window",
  "documentRoot": "/dist/",
  "url": "/",
  "enableServer": true,
  "enableNativeAPI": true,
  "singlePageServe": true,
  "tokenSecurity": "one-time",
  "nativeAllowList": [
    "app.*",
    "os.*",
    "window.*",
    "computer.*",
    "debug.log",
    "filesystem.*"
  ],
  "modes": {
    "window": {
      "title": "Neu Desk",
      "width": 320,
      "height": 64,
      "minWidth": 100,
      "minHeight": 40,
      "borderless": true,
      "transparent": true,
      "alwaysOnTop": true,
      "resizable": false,
      "center": false,
      "useSavedState": false,
      "maximizable": false,
      "icon": "/public/icon.png",
      "enableInspector": false,
      "exitProcessOnClose": true
    }
  },
  "cli": {
    "binaryName": "neu-desk-cli",
    "resourcesPath": "/dist/",
    "extensionsPath": "/extensions/",
    "binaryVersion": "6.8.0",
    "clientVersion": "6.8.0",
    "frontendLibrary": {
      "patchFile": "/index.html",
      "devUrl": "http://localhost:5173",
      "projectPath": "/",
      "initCommand": "npm install",
      "devCommand": "npm run dev:vite",
      "buildCommand": "npm run build:vite"
    }
  }
}